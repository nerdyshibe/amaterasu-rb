#!/usr/bin/env ruby

require_relative '../lib/akane'
require 'stackprof'

options = Akane::CLI.parse(ARGV)

if options[:profile]
  require 'stackprof'

  results = StackProf.run(mode: options[:profile]) do
    Akane::Emulator.start(**options)
  end

  StackProf::Report.new(results).print_text
else
  Akane::Emulator.start(**options)
end
