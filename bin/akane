#!/usr/bin/env ruby
# frozen_string_literal: true

RubyVM::YJIT.enable if defined?(RubyVM::YJIT)

require_relative '../lib/akane'

options = Akane::CLI.parse(ARGV)

if options[:profiling]
  require 'stackprof'

  StackProf.start(mode: options[:profiling].to_sym)

  at_exit do
    StackProf.stop
    results = StackProf.results
    StackProf::Report.new(results).print_text(sort: true, limit: 30)
  end
end

if ENV['PROFILE']
  require 'vernier'

  Vernier.profile(out: 'tmp/vernier_allocs.json', allocation_interval: 1) do
    Akane::Emulator.new(**options).start
  end
else
  Akane::Emulator.new(**options).start
end
