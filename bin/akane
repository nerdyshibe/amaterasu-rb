#!/usr/bin/env ruby

require_relative '../lib/akane'

options = Akane::CLI.parse(ARGV)

if options[:profiling]
  require 'stackprof'

  StackProf.start(mode: options[:profiling].to_sym)

  at_exit do
    StackProf.stop
    results = StackProf.results
    StackProf::Report.new(results).print_text(sort: true, limit: 30)
  end

  Akane::Emulator.new(**options).start
else
  Akane::Emulator.new(**options).start
end
